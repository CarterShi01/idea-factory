# Idea Factory — environment (copy to .env; .env is gitignored, never commit real values)

# --- LLM steps (idea-gen --gen-backend router / idea-eval --judge-backend router) ---
# OpenAI-compatible endpoint (base_url must include the version path, e.g. .../v1).
# These fall back to OPENAI_BASE_URL / OPENAI_API_KEY / OPENAI_MODEL if unset.
IDEA_LLM_BASE_URL=
IDEA_LLM_API_KEY=
IDEA_LLM_MODEL=

# --- Studio control panel (studio/server/app.py) ---
# Shared password for the browser UI + JSON API (empty => auth disabled, dev only).
STUDIO_PASSWORD=
# Optional: cookie HMAC secret (defaults to STUDIO_PASSWORD) and listen port.
STUDIO_SECRET=
STUDIO_PORT=3010

# --- Machine endpoint GET /api/top3 (read-only "today's top-3 ideas") ---
# Bearer token required by downstream agents: Authorization: Bearer <key>.
# Empty => endpoint locked (401 for everyone).
IDEA_TOP3_API_KEY=
