.env
__pycache__/
*.py[cod]
*.egg-info/
.eggs/
build/
dist/
.venv/
venv/

# Tooling caches
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Generated pipeline output (regenerate via the pipeline; never hand-edit)
data/processed/*.json
data/processed/*.md

# LLM batch request/response packs (CC-handoff mode)
data/llm_jobs/

# Dynamic-source state + scrape cache (regenerated; never hand-edit)
data/state/
data/cache/

# Local secrets (real provider keys live only in env / .env, never in git)
.env

# Studio web build artifacts
studio/web/node_modules/
studio/web/dist/
studio/web/*.tsbuildinfo
studio/web/vite.config.js
studio/web/vite.config.d.ts


# ...but keep the directory and the committed sample inputs
!data/processed/.gitkeep

# OC 项目锚(手侧 opt-in,免 git)
.oc/
