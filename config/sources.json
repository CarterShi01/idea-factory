{
  "static_external": { "enabled": true },
  "brain": { "enabled": true },
  "persona": { "enabled": true },

  "hn_algolia": {
    "enabled": true,
    "_note": "enabled 仅表示'live 时启用';默认 live=False 不触网,离线 demo 不受影响",
