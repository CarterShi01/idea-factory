    "cdp_endpoint": "http://100.111.25.20:9222",
    "nav_timeout_ms": 30000,
    "max_items_per_target": 20,
    "targets": [
      {
        "name": "xiaohongshu",
        "category": "独立开发",
        "url": "https://www.xiaohongshu.com/search_result?keyword=%E7%8B%AC%E7%AB%8B%E5%BC%80%E5%8F%91",
        "item_selector": "section.note-item",
        "title_selector": "a.title, span.title"
      },
      {
        "name": "zhihu",
        "category": "创业痛点",
        "url": "https://www.zhihu.com/search?type=content&q=%E5%88%9B%E4%B8%9A%20%E7%97%9B%E7%82%B9",
        "item_selector": ".SearchResult-Card",
